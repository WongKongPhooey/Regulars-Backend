# ── Server ────────────────────────────────────────────────────
PORT=3001

# ── PostgreSQL ────────────────────────────────────────────────
# Standard connection string — works with local Postgres, Supabase, Railway, Render, etc.
# Local example: postgresql://postgres:yourpassword@localhost:5432/regulars
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/regulars
